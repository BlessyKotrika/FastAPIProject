  "components": {
    "schemas": {
      "ChatMessageType": {
        "type": "string",
        "enum": [
          "advice",
          "schemes",
          "refusal",
          "fallback"
        ],
        "title": "ChatMessageType"
      },
      "ChatRequest": {
        "properties": {
          "question": {
            "type": "string",
            "minLength": 1,
            "title": "Question",
            "example": "When should I harvest my wheat?"
          },
          "language": {
            "$ref": "#/components/schemas/Language",
            "default": "hi"
          },
          "crop": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Crop",
            "example": "Wheat"
          },
          "location": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Location",
            "example": "Barabanki"
          },
          "conversation_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Conversation Id",
            "description": "Existing conversation id for multi-turn chat",
            "example": "conv_1f8f0f3a"
          },
          "client_message_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Client Message Id",
            "description": "Client-generated idempotency key for this user message",
            "example": "msg_client_123"
          },
          "advisory_mode": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Advisory Mode",
            "description": "llm or schemes",
            "default": "llm"
          }
        },
        "type": "object",
        "required": [
          "question"
        ],
        "title": "ChatRequest"
      },
      "ChatResponse": {
        "properties": {
          "conversation_id": {
            "type": "string",
            "title": "Conversation Id",
            "description": "Conversation id for continuing chat"
          },
          "message_id": {
            "type": "string",
            "title": "Message Id",
            "description": "Assistant message id"
          },
          "message_type": {
            "$ref": "#/components/schemas/ChatMessageType",
            "description": "Type of assistant response"
          },
          "answer": {
            "type": "string",
            "title": "Answer",
            "description": "AI generated answer to the question"
          },
          "confidence_score": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence Score"
          },
          "citations": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Citations",
            "description": "Source document links"
          },
          "checklist": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Checklist",
            "description": "3-step checklist"
          },
          "do": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Do",
            "description": "Recommended actions"
          },
          "dont": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Dont",
            "description": "Actions to avoid"
          },
          "schemes": {
            "items": {
              "$ref": "#/components/schemas/SchemeItem"
            },
            "type": "array",
            "title": "Schemes",
            "description": "Eligible schemes with details"
          },
          "eligible_schemes": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Eligible Schemes",
            "description": "Legacy list of scheme names"
          },
          "documents_required": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Documents Required",
            "description": "Legacy/global required documents"
          },
          "application_links": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Application Links",
            "description": "Legacy/global application links"
          }
        },
        "type": "object",
        "required": [
          "conversation_id",
          "message_id",
          "message_type",
          "answer",
          "confidence_score"
        ],
        "title": "ChatResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Language": {
        "type": "string",
        "enum": [
          "hi",
          "en",
          "te",
          "ta",
          "bn"
        ],
        "title": "Language"
      },
      "LanguagePreferenceRequest": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id",
            "example": "user_123"
          },
          "language": {
            "$ref": "#/components/schemas/Language",
            "description": "Preferred language"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "language"
        ],
        "title": "LanguagePreferenceRequest"
      },
      "SchemeItem": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Name of the government scheme"
          },
          "description": {
            "type": "string",
            "title": "Description",
            "description": "Brief description of the scheme"
          },
          "documents": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Documents",
            "description": "Required documents for this specific scheme"
          },
          "link": {
            "type": "string",
            "title": "Link",
            "description": "Application link for this specific scheme"
          }
        },
        "type": "object",
        "required": [
          "name",
          "description",
          "documents",
          "link"
        ],
        "title": "SchemeItem"
      },
      "SchemeRequest": {
        "properties": {
          "state": {
            "type": "string",
            "title": "State",
            "example": "Uttar Pradesh"
          },
          "land_size": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Land Size",
            "example": 2.5
          },
          "category": {
            "type": "string",
            "title": "Category",
            "example": "Small"
          },
          "crop": {
            "type": "string",
            "title": "Crop",
            "example": "Wheat"
          },
          "language": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Language"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "state",
          "land_size",
          "category",
          "crop"
        ],
        "title": "SchemeRequest"
      },
      "SchemeResponse": {
        "properties": {
          "schemes": {
            "items": {
              "$ref": "#/components/schemas/SchemeItem"
            },
            "type": "array",
            "title": "Schemes",
            "description": "List of eligible government schemes with their details"
          },
          "eligible_schemes": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Eligible Schemes",
            "description": "List of eligible government scheme names",
            "default": []
          },
          "documents_required": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Documents Required",
            "description": "Global required documents (optional)",
            "default": []
          },
          "application_links": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Application Links",
            "description": "Global application links (optional)",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "schemes"
        ],
        "title": "SchemeResponse"
      },
      "SellSmartRequest": {
        "properties": {
          "crop": {
            "type": "string",
            "title": "Crop",
            "example": "Wheat"
          },
          "location": {
            "type": "string",
            "title": "Location",
            "example": "Barabanki"
          },
          "state": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "State",
            "example": "Uttar Pradesh"
          },
          "language": {
            "$ref": "#/components/schemas/Language",
            "default": "hi"
          }
        },
        "type": "object",
        "required": [
          "crop",
          "location"
        ],
        "title": "SellSmartRequest"
      },
      "SellSmartResponse": {
        "properties": {
          "best_mandi": {
            "type": "string",
            "title": "Best Mandi",
            "description": "Name of the best market to sell"
          },
          "net_price": {
            "type": "number",
            "title": "Net Price",
            "description": "Expected net price per unit"
          },
          "trend_7d": {
            "type": "string",
            "title": "Trend 7D",
            "description": "7-day price trend"
          },
          "forecast_band": {
            "type": "string",
            "title": "Forecast Band",
            "description": "Forecasted price range"
          },
          "confidence_score": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence Score"
          },
          "all_markets": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "All Markets",
            "description": "List of all available markets",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "best_mandi",
          "net_price",
          "trend_7d",
          "forecast_band",
          "confidence_score"
        ],
        "title": "SellSmartResponse"
      },
      "TodayRequest": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id",
            "example": "user_123"
          },
          "crop": {
            "type": "string",
            "title": "Crop",
            "example": "Wheat"
          },
          "location": {
            "type": "string",
            "title": "Location",
            "example": "Barabanki"
          },
          "language": {
            "$ref": "#/components/schemas/Language",
            "default": "hi"
          },
          "sowing_date": {
            "type": "string",
            "title": "Sowing Date",
            "example": "2024-10-15"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "crop",
          "location",
          "sowing_date"
        ],
        "title": "TodayRequest"
      },
      "TodayResponse": {
        "properties": {
          "do": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Do",
            "description": "List of recommended actions for today"
          },
          "avoid": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Avoid",
            "description": "List of actions to avoid today"
          },
          "prepare": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Prepare",
            "description": "Preparation steps for upcoming days"
          },
          "weather_risk": {
            "additionalProperties": true,
            "type": "object",
            "title": "Weather Risk",
            "description": "Weather risk details"
          },
          "current_weather": {
            "additionalProperties": true,
            "type": "object",
            "title": "Current Weather",
            "description": "Current weather snapshot",
            "default": {}
          },
          "confidence_score": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence Score"
          },
          "sources": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Sources",
            "description": "Information sources",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "do",
          "avoid",
          "prepare",
          "weather_risk",
          "confidence_score"
        ],
        "title": "TodayResponse"
      },
